<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Blood Care</title>
<style>
body{font-family:Arial;margin:0;background:#f5f5f5;}
header{background:#c62828;color:white;padding:15px;text-align:center;}
nav{background:#222;padding:10px;text-align:center;}
nav a{color:white;margin:10px;text-decoration:none;}
.hero{background:url('https://images.unsplash.com/photo-1615461066159-fea0960485d5') center/cover;color:white;padding:100px;text-align:center;}
.container{padding:20px;}
input,select{padding:8px;margin:5px;width:90%;}
button{padding:10px;background:#c62828;color:white;border:none;}
.chatbot{position:fixed;bottom:20px;right:20px;width:260px;background:white;border:1px solid #ccc;padding:10px;box-shadow:0 0 10px rgba(0,0,0,0.2);} 
.chatbot img{width:50px;}
</style>
</head>
<body>
<header>
<h1>Blood Care System</h1>
<p>Save Life - Donate Blood</p>
</header>

<nav>
<a href="#home">Home</a>
<a href="#login">Login</a>
<a href="#register">Register</a>
<a href="#donor">Donor Form</a>
<a href="#receiver">Receiver Form</a>
</nav>

<div class="hero" id="home">
<h2>Donate Blood, Save Lives</h2>
<p>Your small help can save someone’s life</p>
</div>

<div class="container" id="login">
<h2>Login</h2>
<input type="text" placeholder="Username"><br>
<input type="password" placeholder="Password"><br>
<button>Login</button>
</div>

<div class="container" id="register">
<h2>Register</h2>
<input type="text" placeholder="Full Name"><br>
<input type="email" placeholder="Email"><br>
<input type="password" placeholder="Password"><br>
<button>Register</button>
</div>

<div class="container" id="donor">
<h2>Donor Form</h2>
<input type="text" placeholder="Donor Name"><br>
<input type="text" placeholder="Mobile Number"><br>
<select>
<option>A+</option><option>A-</option><option>B+</option><option>B-</option>
<option>O+</option><option>O-</option><option>AB+</option><option>AB-</option>
</select><br>
<input type="number" placeholder="Age"><br>
<select><option>Male</option><option>Female</option></select><br>
<input type="text" placeholder="Address"><br>
<button>Submit</button>
</div>

<div class="container" id="receiver">
<h2>Receiver Form</h2>
<input type="text" placeholder="Name"><br>
<input type="number" placeholder="Age"><br>
<input type="text" placeholder="Mobile Number"><br>
<select><option>Male</option><option>Female</option></select><br>
<select>
<option>A+</option><option>A-</option><option>B+</option><option>B-</option>
<option>O+</option><option>O-</option><option>AB+</option><option>AB-</option>
</select><br>
<button>Submit</button>
</div>

<div class="chatbot">
<img src="https://cdn-icons-png.flaticon.com/512/4712/4712109.png">
<h4>AI Help Bot</h4>
<input type="text" id="chatInput" placeholder="Search or ask...">
<button onclick="reply()">Send</button>
<p id="chatOutput"></p>
</div>

<script>
function reply(){
let input=document.getElementById('chatInput').value;
document.getElementById('chatOutput').innerText="We will help you with: "+input;
}
</script>

</body>
</html>
